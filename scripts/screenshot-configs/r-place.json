{
  "name": "r-place",
  "frontendPort": 5173,
  "backendPort": 3000,
  "backendRequired": true,
  "dbName": "rplace",
  "dbUser": "rplace",
  "auth": {
    "enabled": true,
    "loginUrl": "/",
    "credentials": {
      "username": "alice",
