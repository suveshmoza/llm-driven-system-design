    {
      "name": "03-send-money",
      "path": "/send",
      "waitFor": "main, form",
      "delay": 1000
    },
    {
      "name": "04-request-money",
      "path": "/request",
      "waitFor": "main, form",
      "delay": 1000
    },
    {
      "name": "05-activity",
      "path": "/activity",
      "waitFor": "main, h1",
      "delay": 1000
    },
    {
      "name": "06-payment-methods",
      "path": "/payment-methods",
      "waitFor": "main, h1",
      "delay": 1000
    }
