{
  "name": "paypal",
  "frontendPort": 5173,
  "backendPort": 3000,
  "backendRequired": true,
  "dbName": "paypal",
  "dbUser": "paypal",
  "auth": {
    "enabled": true,
    "loginUrl": "/login",
