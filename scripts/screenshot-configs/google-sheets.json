{
  "name": "google-sheets",
  "frontendPort": 5173,
  "backendPort": 3000,
  "backendRequired": true,
  "dbName": "sheets",
  "dbUser": "sheets",
  "auth": {
    "enabled": false
  },
  "screens": [
    {
      "name": "01-spreadsheet",
      "path": "/",
      "waitFor": ".app, .spreadsheet-grid, table, [class*='Grid'], [class*='grid']",
      "skipAuth": true,
      "delay": 2000
    }
  ],
  "viewport": {
    "width": 1440,
    "height": 900
  }
}
